# Omni B2B Telegram Bot — Environment Variables
# Copy this file to .env and fill in the values

# Telegram Bot token obtained from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Omni B2B API
API_BASE_URL=http://localhost:8080

# JWT service token for bot authentication (generate via /auth/login or a dedicated service account)
API_JWT_TOKEN=your-jwt-token-here

# Clinic name used in messages
CLINIC_NAME=Sua Clínica
